# Dependency directories (Folder library yang ukurannya sangat besar)
node_modules/
/jspm_packages/

# Build outputs (Folder hasil compile, akan dibuat otomatis saat deploy)
.next/
out/
build/
dist/

# Local env files (SANGAT PENTING: menyembunyikan API Key, Token, atau kredensial tracking)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env.json

# Debug logs (File log saat ada error)
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# IDE / Editors configurations (File bawaan text editor komputer kamu)
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.DS_Store (Khusus pengguna Mac)